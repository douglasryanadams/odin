# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides
# SEARXNG_URL=http://searxng:8080  # default; change only if running searxng externally
# LOG_LEVEL=INFO                   # default INFO; compose dev overrides to DEBUG
# WORKERS=1                        # default (cpu_count * 2) + 1; set 1 on hosts with < 2GB RAM
# PLAYWRIGHT_HEADLESS=true         # set false only on a host with a display server
# PLAYWRIGHT_TRACE_DIR=            # set to ./traces to capture Playwright trace zips

# Production only
# SEARXNG_SECRET=change-me-32-chars-random  # overrides settings.yml secret_key
