# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
SECRET_KEY=replace-with-32-or-more-random-bytes  # generate via: python -c 'import secrets; print(secrets.token_urlsafe(48))'
APP_URL=http://localhost:8000

# Optional overrides
# SEARXNG_URL=http://searxng:8080  # default; change only if running searxng externally
# LOG_LEVEL=INFO                   # default INFO; compose dev overrides to DEBUG
# WORKERS=1                        # default (cpu_count * 2) + 1; set 1 on hosts with < 2GB RAM
# PLAYWRIGHT_HEADLESS=true         # set false only on a host with a display server
# PLAYWRIGHT_TRACE_DIR=            # set to ./traces to capture Playwright trace zips

# Local-dev override: HTTP localhost cannot accept Secure cookies, which
# would silently break CSRF, session, and notice-dismissal flows. Prod
# omits this so the code default (True) applies and Set-Cookie carries
# Secure on HTTPS.
COOKIE_SECURE=false

# Production only
# SEARXNG_SECRET=change-me-32-chars-random  # overrides settings.yml secret_key

# Magic link delivery
# Defaults target Purelymail (smtp.purelymail.com:587) and odin@odinseye.info.
# Without SMTP_USER/SMTP_PASS the link is logged to stdout instead of sent (dev mode).
# SMTP_USER=odin@yourdomain.com           # mailbox / submission username
# SMTP_PASS=                              # submission password
# SMTP_HOST=smtp.purelymail.com           # override to use a different provider
# SMTP_PORT=587
# SMTP_FROM=odin@odinseye.info            # override to send from your own domain

# Site contact address shown on /privacy and /terms
# CONTACT_EMAIL=odin@odinseye.info
