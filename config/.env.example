# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
BRAVE_API_KEY=your-brave-search-api-key   # provision at https://api-dashboard.search.brave.com/ — consumed by the web service's Brave backend. Without it the Brave backend is not constructed and only the Wikipedia backend runs.
SECRET_KEY=replace-with-32-or-more-random-bytes  # generate via: python -c 'import secrets; print(secrets.token_urlsafe(48))'
APP_URL=http://localhost:8000

# Optional overrides
# LOG_LEVEL=INFO                   # default INFO; compose dev overrides to DEBUG
# WORKERS=1                        # default (cpu_count * 2) + 1; set 1 on hosts with < 2GB RAM
# PLAYWRIGHT_HEADLESS=true         # set false only on a host with a display server
# PLAYWRIGHT_TRACE_DIR=            # set to ./traces to capture Playwright trace zips
# PLAYWRIGHT_CHANNEL=              # default bundled Chromium; set e.g. "chrome" if a real Chrome channel is installed in the image
# PLAYWRIGHT_STORAGE_STATE_PATH=/var/lib/odin/playwright-state/state.json  # default; set "" to disable persistence
# FETCH_CURL_CFFI_ENABLED=true     # default true; set false to skip Tier 0 and always use Playwright

# Local-dev override: HTTP localhost cannot accept Secure cookies, which
# would silently break CSRF, session, and notice-dismissal flows. Prod
# omits this so the code default (True) applies and Set-Cookie carries
# Secure on HTTPS.
COOKIE_SECURE=false

# Database (durable store for signups and search history)
# Postgres runs in-stack with two roles. The owner/migrator role (POSTGRES_PASSWORD)
# runs Alembic and owns the schema; the least-privilege runtime role
# (ODIN_APP_DB_PASSWORD) is what the app connects as and cannot alter schema. Both
# default for local dev; in prod, deploy.sh sources both from the odin/app secret
# (required, no fallback). The initdb script creates the runtime role on first
# volume init, so an existing dev volume must be recreated (docker compose down -v)
# to pick it up.
# POSTGRES_PASSWORD=odin
# ODIN_APP_DB_PASSWORD=odin_app
# Compose builds DATABASE_URL (runtime role); the deploy injects DATABASE_MIGRATION_URL
# (owner role) into the one-off migration container only. Override DATABASE_URL
# directly to point the app at an external Postgres (e.g. RDS).
# DATABASE_URL=postgresql://odin_app:odin_app@odin-postgres:5432/odin

# Magic link delivery
# Defaults target Purelymail (smtp.purelymail.com:587) and odin@odinseye.info.
# Without SMTP_USER/SMTP_PASS the link is logged to stdout instead of sent (dev mode).
# SMTP_USER=odin@yourdomain.com           # mailbox / submission username
# SMTP_PASS=                              # submission password
# SMTP_HOST=smtp.purelymail.com           # override to use a different provider
# SMTP_PORT=587
# SMTP_FROM=odin@odinseye.info            # override to send from your own domain

# Site contact address shown on /privacy and /terms; also composed into the
# Wikipedia backend's User-Agent for Wikimedia's policy compliance.
# CONTACT_EMAIL=odin@odinseye.info
