use_default_settings:
  engines:
    remove:
      - ahmia
      - torch
      - wikidata
      - duckduckgo
      - google
      - bing
      - yahoo

server:
  # Override in production via SEARXNG_SECRET environment variable
  secret_key: "dev-secret-key-not-for-production"
  # Disabled: SearXNG is reachable only on the Docker bridge and EC2 security
  # group, and the botdetection PASSLIST logger fires a WARNING on every
  # request from a passlisted IP — which is every Odin request.
  limiter: false
  image_proxy: true

search:
  formats:
    - html
    - json
  # When an engine returns an error (e.g. Mojeek 403), SearXNG suspends it
  # for ban_time_on_fail seconds, then doubles on each repeat failure up to
  # max_ban_time_on_fail. Initial 10 min / cap 1 hour avoids the noisy
  # 10s/20s/40s ramp on persistently-blocked scrapers; transient errors on
  # the working engines still recover within the next request.
  ban_time_on_fail: 600
  max_ban_time_on_fail: 3600

outgoing:
  request_timeout: 6.0
  max_request_timeout: 30.0
  pool_connections: 100
  pool_maxsize: 20
  enable_http2: true
  retries: 1
  # Uncomment source_ips if your host has multiple IPs (e.g., IPv4 + IPv6).
  # SearXNG rotates outbound requests across these addresses, reducing per-IP request rates:
  # source_ips:
  #   - 0.0.0.0
  #   - "::"
  #
  # For a proxy pool, add:
  # proxies:
  #   all://:
  #     - http://proxy1:port
  #     - http://proxy2:port
  # extra_proxy_timeout: 10.0

engines:
  # Brave Search API. Replaces the scraping `brave` engine, which was
  # consistently blocked. ${BRAVE_API_KEY} is substituted at container start
  # by searxng/entrypoint.sh; see docs/searxng.md.
  - name: brave
    engine: braveapi
    api_key: "${BRAVE_API_KEY}"
    results_per_page: 20
    disabled: false

  # Mojeek is an independent index. Free, and the most cooperative of the
  # scrapers SearXNG ships, though it can still rate-limit cloud IPs.
  - name: mojeek
    engine: mojeek
    disabled: false

  # The remaining defaults are SERP scrapers (Google, Bing, etc.) behind
  # proxies; from a single cloud IP they consistently return CAPTCHA or
  # access-denied. Wikipedia returns HTTP 429 because SearXNG identifies
  # itself as `searxng/<version>` and that trips Wikimedia's bot rate
  # limit (no per-engine User-Agent override is supported). Cannot use
  # `engines.remove` because SearXNG's network config references some of
  # these names as network aliases, so we override each entry with
  # `disabled: true` instead.
  - name: startpage
    engine: startpage
    disabled: true
  - name: qwant
    engine: qwant
    disabled: true
  - name: karmasearch
    engine: karmasearch
    disabled: true
  - name: wikipedia
    engine: wikipedia
    disabled: true

valkey:
  url: redis://searxng-valkey:6379/0
